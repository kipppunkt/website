---
const route = Astro.locals.starlightRoute;
const isHome = route.id === '';
const body = route.entry.body ?? '';
---

<div class="page-title-row">
	<h1 id="_top">{route.entry.data.title}</h1>
	{!isHome && (
		<button class="copy-md-btn" data-md={body} aria-label="Copy page as Markdown">
			<svg class="icon-copy" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
				<path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path>
				<rect x="8" y="2" width="8" height="4" rx="1" ry="1"></rect>
			</svg>
			<span class="copy-text">Copy page</span>
		</button>
	)}
</div>

<style>
	@layer starlight.custom {
		h1 {
			margin-top: 1rem;
			font-size: var(--sl-text-h1);
			line-height: var(--sl-line-height-headings);
			font-weight: 600;
			color: var(--sl-color-white);
			flex: 1 1 auto;
			min-width: 0;
			overflow-wrap: anywhere;
		}

		.page-title-row {
			display: flex;
			align-items: baseline;
			justify-content: space-between;
			gap: 0.75rem;
		}

		.copy-md-btn {
			flex-shrink: 0;
			align-self: end;
			height: 36px;
			display: inline-flex;
			align-items: center;
			gap: 0.375rem;
			background: none;
			border: 1px solid var(--sl-color-gray-5);
			border-radius: 0.375rem;
			padding: 0.25rem 0.5rem;
			color: var(--sl-color-gray-3);
			cursor: pointer;
			font-size: var(--sl-text-xs);
			line-height: 1;
			transition: color 0.15s, border-color 0.15s;
		}

		.copy-md-btn:hover {
			color: var(--sl-color-white);
			border-color: var(--sl-color-gray-3);
		}
	}
</style>

<script>
	document.addEventListener('click', async (e) => {
		const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.copy-md-btn');
		if (!btn) return;
		const md = btn.dataset.md ?? '';
		try {
			await navigator.clipboard.writeText(md);
			const textEl = btn.querySelector<HTMLSpanElement>('.copy-text')!;
			textEl.textContent = 'Copied!';
			setTimeout(() => {
				textEl.textContent = 'Copy page';
			}, 2000);
		} catch {
			// Clipboard API not available
		}
	});
</script>
